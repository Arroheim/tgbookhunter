# Telegram API credentials
# Get these from https://my.telegram.org/
TG_API_ID=your_api_id_here
TG_API_HASH=your_api_hash_here
TG_PHONE=your_phone_number_here

# Download settings
DOWNLOAD_DIR=./downloads
MAX_CONCURRENT_DOWNLOADS=3

# Book formats to download (JSON format for lists)
BOOK_FORMATS=["pdf", "djvu", "mobi", "epub", "fb2", "cbr", "cbz"]

# Rate limiting (seconds between requests, 0.1 = faster scanning)
RATE_LIMIT_DELAY=0.1

# Logging
LOG_LEVEL=INFO
LOG_FILE=tgbookhunter.log
